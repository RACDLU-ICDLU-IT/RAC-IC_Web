{
  "entities": {
    "User": {
      "title": "User",
      "description": "A member or admin profile.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["member", "officer", "admin", "rotary_advisor"] },
        "status": { "type": "string", "enum": ["pending", "active", "inactive"] },
        "school": { "type": "string" },
        "grade": { "type": "string" },
        "class": { "type": "string" },
        "gender": { "type": "string" },
        "dob": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "phone": { "type": "string" },
        "parentName": { "type": "string" },
        "parentPhone": { "type": "string" },
        "bio": { "type": "string" },
        "avatar": { "type": "string" },
        "socialLinks": {
          "type": "object",
          "properties": {
            "facebook": { "type": "string" },
            "instagram": { "type": "string" },
            "linkedin": { "type": "string" }
          }
        },
        "joinDate": { "type": "number" },
        "rotaryYear": { "type": "string" },
        "notificationPrefs": {
          "type": "object",
          "properties": {
            "email": { "type": "boolean" },
            "push": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "role", "status"]
    },
    "Event": {
      "title": "Event",
      "description": "A club event.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["Meeting", "Community Project", "International", "Social"] },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "venue": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "type", "date"]
    },
    "Attendance": {
      "title": "Attendance record",
      "description": "Records member attendance for an event.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "eventId": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent", "excused", "late"] },
        "markedAt": { "type": "number" },
        "markedBy": { "type": "string" }
      },
      "required": ["userId", "eventId", "status"]
    },
    "Project": {
      "title": "Project",
      "description": "A club project.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["upcoming", "ongoing", "completed"] },
        "startDate": { "type": "string" },
        "coverImage": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "status"]
    },
    "Application": {
      "title": "Application",
      "description": "A join application.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "dob": { "type": "string" },
        "phone": { "type": "string" },
        "school": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "rejectionNote": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "email", "status"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "A club announcement.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "body", "authorId"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "A club-wide reminder.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string" },
        "targetRole": { "type": "string", "enum": ["all members", "officers only"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "dueDate", "targetRole"]
    },
    "News": {
      "title": "News",
      "description": "A news article.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "coverImage": { "type": "string" },
        "category": { "type": "string" },
        "body": { "type": "string" },
        "publishedAt": { "type": "number" },
        "status": { "type": "string", "enum": ["published", "draft"] },
        "authorId": { "type": "string" }
      },
      "required": ["title", "body", "status"]
    },
    "GalleryPhoto": {
      "title": "Gallery Photo",
      "description": "A photo in the gallery.",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "caption": { "type": "string" },
        "albumTag": { "type": "string" },
        "eventId": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["url"]
    },
    "Sponsor": {
      "title": "Sponsor",
      "description": "A club sponsor.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "tier": { "type": "string", "enum": ["Platinum", "Gold", "Silver", "Bronze"] },
        "description": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "tier"]
    },
    "BoardMember": {
      "title": "Board Member",
      "description": "A member of the club's board.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "position": { "type": "string" },
        "photoUrl": { "type": "string" },
        "bio": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name", "position"]
    },
    "Resource": {
      "title": "Resource",
      "description": "A document or link for members.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["File", "Link"] },
        "url": { "type": "string" },
        "visibility": { "type": "string", "enum": ["all members", "officers"] },
        "uploadedBy": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "type", "url"]
    },
    "PageContent": {
      "title": "Page Content",
      "description": "Content for public pages.",
      "type": "object",
      "properties": {},
      "required": []
    },
    "ContactMessage": {
      "title": "Contact Message",
      "description": "A message submitted via the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "email", "message"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Member profiles."
    },
    "/events/{eventId}": {
      "schema": { "$ref": "#/entities/Event" },
      "description": "Club events."
    },
    "/attendance/{attendanceId}": {
      "schema": { "$ref": "#/entities/Attendance" },
      "description": "Attendance tracking."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Club projects."
    },
    "/applications/{applicationId}": {
      "schema": { "$ref": "#/entities/Application" },
      "description": "Join applications."
    },
    "/announcements/{announcementId}": {
      "schema": { "$ref": "#/entities/Announcement" },
      "description": "Announcements."
    },
    "/reminders/{reminderId}": {
      "schema": { "$ref": "#/entities/Reminder" },
      "description": "Reminders."
    },
    "/news/{newsId}": {
      "schema": { "$ref": "#/entities/News" },
      "description": "News articles."
    },
    "/gallery/{photoId}": {
      "schema": { "$ref": "#/entities/GalleryPhoto" },
      "description": "Gallery photos."
    },
    "/sponsors/{sponsorId}": {
      "schema": { "$ref": "#/entities/Sponsor" },
      "description": "Club sponsors."
    },
    "/board/{memberId}": {
      "schema": { "$ref": "#/entities/BoardMember" },
      "description": "Board members."
    },
    "/resources/{resourceId}": {
      "schema": { "$ref": "#/entities/Resource" },
      "description": "Resources."
    },
    "/pageContent/{pageId}": {
      "schema": { "$ref": "#/entities/PageContent" },
      "description": "CMS content."
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/PageContent" },
      "description": "Global and theme settings."
    },
    "/contact_messages/{messageId}": {
      "schema": { "$ref": "#/entities/ContactMessage" },
      "description": "Contact form submissions."
    }
  }
}
